{
  "buildCommand": null,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/search-api", "dest": "/api/search-api.php" },
    { "src": "/login", "dest": "/api/login.php" },
    { "src": "/skelbiu", "dest": "/api/skelbiu.php" },
    { "src": "/autoplius", "dest": "/api/autoplius.php" },
    { "src": "/aruodas", "dest": "/api/aruodas.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
